# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# URL pública da aplicação (usada em OG Image e e-mails transacionais)
NUXT_PUBLIC_SITE_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# URL do projeto Supabase (Settings > API > Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Chave anônima pública — segura para expor no cliente (Settings > API > anon public)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de serviço — NUNCA exponha no cliente, usada apenas no servidor (Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------

# Chave secreta da API Stripe — usada no servidor para criar sessões e clientes
# Produção: sk_live_...  |  Desenvolvimento: sk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Segredo para validar a assinatura dos webhooks recebidos do Stripe
# Obtenha em: Dashboard > Developers > Webhooks > seu endpoint > Signing secret
# Produção: whsec_...  |  Desenvolvimento (Stripe CLI): whsec_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs dos planos de assinatura (Dashboard > Products > seu produto > Price ID)
NUXT_PUBLIC_STRIPE_PRICE_ID_STARTER=price_...
NUXT_PUBLIC_STRIPE_PRICE_ID_PRO=price_...


# -----------------------------------------------------------------------------
# OneSignal — notificações push (opcional)
# -----------------------------------------------------------------------------

# Habilita OneSignal apenas em produção (true/false)
NUXT_PUBLIC_ONESIGNAL_ENABLED=false

# App ID do OneSignal (Dashboard > Settings > Keys & IDs)
NUXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# Caminhos dos service workers (padrão abaixo — altere só se necessário)
NUXT_PUBLIC_ONESIGNAL_SERVICE_WORKER_PATH=/push/onesignal/OneSignalSDKWorker.js
NUXT_PUBLIC_ONESIGNAL_SERVICE_WORKER_UPDATER_PATH=/push/onesignal/OneSignalSDKUpdaterWorker.js
NUXT_PUBLIC_ONESIGNAL_SERVICE_WORKER_SCOPE=/push/onesignal/


# -----------------------------------------------------------------------------
# PostHog — analytics de produto (opcional)
# -----------------------------------------------------------------------------

# Habilita PostHog apenas em produção (true/false)
NUXT_PUBLIC_POSTHOG_ENABLED=false

# Chave do projeto PostHog (Project Settings > Project API key)
NUXT_PUBLIC_POSTHOG_KEY=phc_...

# Host do PostHog (use o padrão ou o seu proxy reverso)
NUXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com


# -----------------------------------------------------------------------------
# Consulta de placas veiculares (opcional)
# -----------------------------------------------------------------------------

# Token de autenticação da API wdapi2.com.br para consulta de dados pelo número da placa
# Obtenha em: https://wdapi2.com.br
WDAPI_TOKEN=

# URL base da API de placas (opcional — padrão: https://wdapi2.com.br/consulta)
# Troque aqui caso queira usar outro provedor compatível com o formato /{placa}/{token}
# PLATE_API_URL=https://wdapi2.com.br/consulta
